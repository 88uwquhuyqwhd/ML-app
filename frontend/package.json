{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "description": "ML Studio Windows desktop app for machine learning and statistical analysis",
  "author": "ML Studio Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:backend": "cd ../backend && venv\\Scripts\\python.exe build_backend.py",
    "build:all": "npm run build:backend && npm run build",
    "package:win": "npm run build:all && electron-builder --win nsis --publish never",
    "package:dir": "npm run build:all && electron-builder --win dir --publish never",
    "package:portable": "npm run package:dir && powershell -ExecutionPolicy Bypass -File ..\\scripts\\make-portable.ps1"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "axios": "^1.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.mlapp.desktop",
    "productName": "ML Studio",
    "directories": {
      "output": "release"
    },
    "artifactName": "ML-Studio-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "../backend/dist/api",
        "to": "api"
      },
      {
        "from": "../demo_datasets",
        "to": "demo_datasets"
      }
    ]
  }
}
